// https://mozilla.org/MPL/2.0/
// © hungpixi — Comarai (https://comarai.com)
// Reference: jbondata/pinescript-indicator-suite, FibAlgo ICT Premium & Discount
//@version=6
indicator("ICT SSL Premium & Discount", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
// Fractal / Swing Detection
grpSwing       = "🔍 Swing Detection"
int leftBars   = input.int(3, "Fractal Bars (each side)", minval=1, maxval=10, group=grpSwing, tooltip="Bars mỗi bên để xác nhận fractal. 3 = 7-bar fractal.")
int maxSwings  = input.int(10, "Max Swings to Show", minval=3, maxval=20, group=grpSwing)

// SSL / BSL Display
grpLiq         = "💧 Liquidity Levels"
bool showBSL   = input.bool(true, "Show BSL (Buy-Side Liquidity)", group=grpLiq)
bool showSSL   = input.bool(true, "Show SSL (Sell-Side Liquidity)", group=grpLiq)
color colBSL   = input.color(color.new(#089981, 0), "BSL Color", group=grpLiq)
color colSSL   = input.color(color.new(#F23645, 0), "SSL Color", group=grpLiq)
int lineWidth  = input.int(1, "Line Width", minval=1, maxval=4, group=grpLiq)

// Sweep Detection
grpSweep       = "⚡ Sweep Detection"
bool showSweep = input.bool(true, "Show Sweep Labels", group=grpSweep)
color colSweepBull = input.color(color.new(#089981, 0), "Bullish Sweep Color", group=grpSweep)
color colSweepBear = input.color(color.new(#F23645, 0), "Bearish Sweep Color", group=grpSweep)

// Premium / Discount Zones
grpPD          = "📊 Premium & Discount Zones"
bool showPD    = input.bool(true, "Show Premium / Discount", group=grpPD)
int pdLookback = input.int(50, "Dealing Range Lookback", minval=10, maxval=200, group=grpPD)
color colPrem  = input.color(color.new(#F23645, 88), "Premium Zone", group=grpPD)
color colDisc  = input.color(color.new(#089981, 88), "Discount Zone", group=grpPD)
color colEQ    = input.color(color.new(#787B86, 30), "Equilibrium Line", group=grpPD)

// OTE Zone
grpOTE         = "🎯 OTE Zone"
bool showOTE   = input.bool(true, "Show OTE (62%-79%)", group=grpOTE)
color colOTE   = input.color(color.new(#FF9800, 85), "OTE Zone Color", group=grpOTE)

// ─── ENTRY / SL / TP SETTINGS ─────────────────────────────────────────────────
grpEntry       = "🎯 Entry Signals (SL/TP)"
bool showEntry = input.bool(true, "Show Entry Signals", group=grpEntry)
bool requireOTE = input.bool(false, "Require OTE Zone for Entry", group=grpEntry, tooltip="Chỉ hiện signal khi sweep xảy ra trong OTE zone — setup chất lượng cao hơn nhưng ít tín hiệu hơn.")
float rrRatio  = input.float(2.0, "Risk:Reward Ratio (fallback)", minval=1.0, maxval=5.0, step=0.5, group=grpEntry, tooltip="Dùng khi không tìm được liquidity level đối diện. 2.0 = TP gấp đôi SL.")
int maxTrades  = input.int(5, "Max Active Trades Shown", minval=1, maxval=20, group=grpEntry)
bool showTP2   = input.bool(true, "Show TP2 (at EQ)", group=grpEntry, tooltip="TP2 tại đường Equilibrium. Partial close tại đây.")
bool showTP3   = input.bool(false, "Show TP3 (opposite zone)", group=grpEntry, tooltip="TP3 tại vùng ngược lại (Premium→Discount hoặc ngược lại).")
int cooldownBars = input.int(5, "Cooldown (bars)", minval=1, maxval=30, group=grpEntry, tooltip="Chờ N bars sau mỗi signal trước khi cho signal tiếp.")
bool oneAtATime = input.bool(true, "One Trade at a Time", group=grpEntry, tooltip="Phải chạm SL hoặc TP mới cho signal mới.")
color colBuy   = input.color(color.new(#00E676, 0), "Buy Signal Color", group=grpEntry)
color colSell  = input.color(color.new(#FF1744, 0), "Sell Signal Color", group=grpEntry)
color colSL    = input.color(color.new(#FF5252, 0), "SL Line Color", group=grpEntry)
color colTP    = input.color(color.new(#69F0AE, 0), "TP Line Color", group=grpEntry)

// Dashboard
grpDash        = "📋 Dashboard"
bool showDash  = input.bool(true, "Show Dashboard", group=grpDash)
string dashPos = input.string("Top Right", "Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group=grpDash)

// ─── FRACTAL DETECTION ────────────────────────────────────────────────────────
float highestInRange = ta.highest(high, leftBars * 2 + 1)
float lowestInRange  = ta.lowest(low, leftBars * 2 + 1)
bool isFractalHigh   = high[leftBars] == highestInRange and high[leftBars] > high[leftBars - 1] and high[leftBars] > high[leftBars + 1]
bool isFractalLow    = low[leftBars] == lowestInRange and low[leftBars] < low[leftBars - 1] and low[leftBars] < low[leftBars + 1]

// ─── LIQUIDITY LEVEL ARRAYS ──────────────────────────────────────────────────
// BSL arrays (swing highs)
var array<line>  linesBSL    = array.new_line()
var array<int>   barsBSL     = array.new_int()
var array<float> pricesBSL   = array.new_float()
var array<bool>  brokenBSL   = array.new_bool()
var array<bool>  sweptBSL    = array.new_bool()

// SSL arrays (swing lows)
var array<line>  linesSSL    = array.new_line()
var array<int>   barsSSL     = array.new_int()
var array<float> pricesSSL   = array.new_float()
var array<bool>  brokenSSL   = array.new_bool()
var array<bool>  sweptSSL    = array.new_bool()

int fractalBar = bar_index - leftBars

// ─── PUSH NEW SWING HIGHS (BSL) ──────────────────────────────────────────────
if isFractalHigh and barstate.isconfirmed and showBSL
    float swingPrice = high[leftBars]
    line ln = line.new(fractalBar, swingPrice, fractalBar + 20, swingPrice, xloc.bar_index, color=colBSL, width=lineWidth, style=line.style_solid)
    array.push(linesBSL, ln)
    array.push(barsBSL, fractalBar)
    array.push(pricesBSL, swingPrice)
    array.push(brokenBSL, false)
    array.push(sweptBSL, false)
    // Trim oldest
    if array.size(linesBSL) > maxSwings
        line.delete(array.shift(linesBSL))
        array.shift(barsBSL)
        array.shift(pricesBSL)
        array.shift(brokenBSL)
        array.shift(sweptBSL)

// ─── PUSH NEW SWING LOWS (SSL) ──────────────────────────────────────────────
if isFractalLow and barstate.isconfirmed and showSSL
    float swingPrice = low[leftBars]
    line ln = line.new(fractalBar, swingPrice, fractalBar + 20, swingPrice, xloc.bar_index, color=colSSL, width=lineWidth, style=line.style_solid)
    array.push(linesSSL, ln)
    array.push(barsSSL, fractalBar)
    array.push(pricesSSL, swingPrice)
    array.push(brokenSSL, false)
    array.push(sweptSSL, false)
    // Trim oldest
    if array.size(linesSSL) > maxSwings
        line.delete(array.shift(linesSSL))
        array.shift(barsSSL)
        array.shift(pricesSSL)
        array.shift(brokenSSL)
        array.shift(sweptSSL)

// ─── PREMIUM & DISCOUNT ZONES (calculated before sweep detection) ────────────
float rangeHigh = ta.highest(high, pdLookback)
float rangeLow  = ta.lowest(low, pdLookback)
float eq        = (rangeHigh + rangeLow) / 2.0

// OTE zone
float rangeSize   = rangeHigh - rangeLow
float oteBuyHigh  = rangeLow + rangeSize * 0.382   // 38.2% from bottom = 61.8% retracement from top
float oteBuyLow   = rangeLow + rangeSize * 0.21    // 21% from bottom = 79% retracement from top
float oteSellHigh = rangeLow + rangeSize * 0.79    // 79% from bottom
float oteSellLow  = rangeLow + rangeSize * 0.618   // 61.8% from bottom

bool inPremium  = close > eq
bool inDiscount = close <= eq
bool inOTEBuy   = close >= oteBuyLow and close <= oteBuyHigh
bool inOTESell  = close >= oteSellLow and close <= oteSellHigh

// ─── TRADE STATE ─────────────────────────────────────────────────────────────
var array<line>  tradeSLLines  = array.new_line()
var array<line>  tradeTP1Lines = array.new_line()
var array<line>  tradeTP2Lines = array.new_line()
var array<line>  tradeTP3Lines = array.new_line()
var array<label> tradeLabels   = array.new_label()
var array<int>   tradeBars     = array.new_int()
var array<float> tradeEntries  = array.new_float()
var array<float> tradeSLs      = array.new_float()
var array<float> tradeTP1s     = array.new_float()
var array<int>   tradeDirs     = array.new_int() // 1=buy, -1=sell
var array<bool>  tradeActive   = array.new_bool()

var int totalBuys      = 0
var int totalSells     = 0
var int totalTPHits    = 0
var int totalSLHits    = 0
var int lastSignalBar  = 0
var bool hasActiveTrade = false
var float activeSL     = na
var float activeTP     = na
var int   activeDir    = 0

// ─── HELPER: Create trade visualization ──────────────────────────────────────
f_drawTrade(int dir, float entry, float sl, float tp1, float tp2, float tp3) =>
    // Colors
    color sigCol = dir == 1 ? colBuy : colSell
    string sigText = dir == 1 ? "🟢 BUY" : "🔴 SELL"
    float riskPips = math.abs(entry - sl)
    float rrActual = riskPips > 0 ? math.abs(tp1 - entry) / riskPips : 0

    // Entry label
    label entryLbl = label.new(bar_index, dir == 1 ? low : high, 
         sigText + "\nEntry: " + str.tostring(entry, format.mintick) + 
         "\nSL: " + str.tostring(sl, format.mintick) + 
         "\nTP1: " + str.tostring(tp1, format.mintick) + 
         "\nR:R " + str.tostring(rrActual, "#.#"),
         color=sigCol, textcolor=color.white, 
         style=dir == 1 ? label.style_label_up : label.style_label_down, 
         size=size.small)

    // SL line (red, dashed)
    line slLine = line.new(bar_index, sl, bar_index + 15, sl, 
         color=colSL, width=2, style=line.style_dashed)

    // TP1 line (green, dashed) — based on R:R
    line tp1Line = line.new(bar_index, tp1, bar_index + 15, tp1, 
         color=colTP, width=2, style=line.style_dashed)

    // TP2 line at EQ (if enabled)
    line tp2Line = na
    if showTP2 and not na(tp2)
        tp2Line := line.new(bar_index, tp2, bar_index + 15, tp2, 
             color=color.new(#42A5F5, 0), width=1, style=line.style_dotted)

    // TP3 line at opposite zone (if enabled)
    line tp3Line = na
    if showTP3 and not na(tp3)
        tp3Line := line.new(bar_index, tp3, bar_index + 15, tp3, 
             color=color.new(#AB47BC, 0), width=1, style=line.style_dotted)

    // SL/TP labels
    label.new(bar_index + 15, sl, "SL", color=color.new(color.white, 100), 
         textcolor=colSL, style=label.style_label_left, size=size.tiny)
    label.new(bar_index + 15, tp1, "TP1 (R:" + str.tostring(rrActual, "#.#") + ")", 
         color=color.new(color.white, 100), textcolor=colTP, 
         style=label.style_label_left, size=size.tiny)
    if showTP2 and not na(tp2)
        label.new(bar_index + 15, tp2, "TP2 (EQ)", color=color.new(color.white, 100), 
             textcolor=color.new(#42A5F5, 0), style=label.style_label_left, size=size.tiny)
    if showTP3 and not na(tp3)
        label.new(bar_index + 15, tp3, "TP3", color=color.new(color.white, 100), 
             textcolor=color.new(#AB47BC, 0), style=label.style_label_left, size=size.tiny)

    // Entry-to-SL zone fill (red background)
    box.new(bar_index, entry, bar_index + 15, sl, 
         border_color=color.new(colSL, 70), bgcolor=color.new(colSL, 92), 
         border_width=1, border_style=line.style_dotted)

    // Entry-to-TP1 zone fill (green background)
    box.new(bar_index, entry, bar_index + 15, tp1, 
         border_color=color.new(colTP, 70), bgcolor=color.new(colTP, 92), 
         border_width=1, border_style=line.style_dotted)

    // Store trade data
    array.push(tradeSLLines, slLine)
    array.push(tradeTP1Lines, tp1Line)
    array.push(tradeTP2Lines, tp2Line)
    array.push(tradeTP3Lines, tp3Line)
    array.push(tradeLabels, entryLbl)
    array.push(tradeBars, bar_index)
    array.push(tradeEntries, entry)
    array.push(tradeSLs, sl)
    array.push(tradeTP1s, tp1)
    array.push(tradeDirs, dir)
    array.push(tradeActive, true)

    // Trim oldest trades
    if array.size(tradeLabels) > maxTrades
        line.delete(array.shift(tradeSLLines))
        line.delete(array.shift(tradeTP1Lines))
        line.delete(array.shift(tradeTP2Lines))
        line.delete(array.shift(tradeTP3Lines))
        label.delete(array.shift(tradeLabels))
        array.shift(tradeBars)
        array.shift(tradeEntries)
        array.shift(tradeSLs)
        array.shift(tradeTP1s)
        array.shift(tradeDirs)
        array.shift(tradeActive)

// ─── UPDATE BSL LEVELS & SWEEP DETECTION + SELL ENTRIES ──────────────────────
var int bslSweepCount = 0
bool bslSweepNow = false
float bslSweepPrice = na

for i = 0 to array.size(linesBSL) - 1
    if i >= array.size(linesBSL)
        break
    line  ln       = array.get(linesBSL, i)
    float priceI   = array.get(pricesBSL, i)
    int   barI     = array.get(barsBSL, i)
    bool  wasBroken = array.get(brokenBSL, i)
    bool  wasSwept  = array.get(sweptBSL, i)

    if not wasBroken
        // Extend line to current bar
        line.set_xy2(ln, bar_index, priceI)

        // Sweep detection: wick above level but close below
        if high >= priceI and close < priceI and not wasSwept
            // Sweep! Wick touched but close didn't break
            array.set(sweptBSL, i, true)
            bslSweepCount += 1
            bslSweepNow := true
            bslSweepPrice := priceI
            if showSweep
                label.new(bar_index, high, "▼ BSL Sweep", color=colSweepBear, textcolor=color.white, style=label.style_label_down, size=size.small)

        // Broken: close above level
        if close > priceI
            array.set(brokenBSL, i, true)
            line.set_xy2(ln, bar_index, priceI)
            line.set_style(ln, line.style_dashed)

    // If already broken, keep dashed style and don't extend
    if wasBroken
        line.set_style(ln, line.style_dashed)

// ─── UPDATE SSL LEVELS & SWEEP DETECTION + BUY ENTRIES ──────────────────────
var int sslSweepCount = 0
bool sslSweepNow = false
float sslSweepPrice = na

for i = 0 to array.size(linesSSL) - 1
    if i >= array.size(linesSSL)
        break
    line  ln       = array.get(linesSSL, i)
    float priceI   = array.get(pricesSSL, i)
    int   barI     = array.get(barsSSL, i)
    bool  wasBroken = array.get(brokenSSL, i)
    bool  wasSwept  = array.get(sweptSSL, i)

    if not wasBroken
        // Extend line to current bar
        line.set_xy2(ln, bar_index, priceI)

        // Sweep detection: wick below level but close above
        if low <= priceI and close > priceI and not wasSwept
            // Sweep! Wick touched but close didn't break
            array.set(sweptSSL, i, true)
            sslSweepCount += 1
            sslSweepNow := true
            sslSweepPrice := priceI
            if showSweep
                label.new(bar_index, low, "▲ SSL Sweep", color=colSweepBull, textcolor=color.white, style=label.style_label_up, size=size.small)

        // Broken: close below level
        if close < priceI
            array.set(brokenSSL, i, true)
            line.set_xy2(ln, bar_index, priceI)
            line.set_style(ln, line.style_dashed)

    // If already broken, keep dashed style and don't extend
    if wasBroken
        line.set_style(ln, line.style_dashed)

// ─── CHECK ACTIVE TRADE: SL/TP HIT (before new signals) ─────────────────────
if hasActiveTrade
    bool slHit = activeDir == 1 ? low <= activeSL : high >= activeSL
    bool tpHit = activeDir == 1 ? high >= activeTP : low <= activeTP
    if slHit
        hasActiveTrade := false
        totalSLHits += 1
        label.new(bar_index, activeDir == 1 ? low : high, "✖ SL",
             color=color.new(#FF5252, 0), textcolor=color.white,
             style=activeDir == 1 ? label.style_label_up : label.style_label_down,
             size=size.tiny)
        activeSL := na
        activeTP := na
        activeDir := 0
    else if tpHit
        hasActiveTrade := false
        totalTPHits += 1
        label.new(bar_index, activeDir == 1 ? high : low, "✔ TP",
             color=color.new(#69F0AE, 0), textcolor=color.white,
             style=activeDir == 1 ? label.style_label_down : label.style_label_up,
             size=size.tiny)
        activeSL := na
        activeTP := na
        activeDir := 0

// ─── HELPER: Find nearest opposite liquidity level ───────────────────────────
// BUY → TP = nearest un-broken BSL (swing high) above entry
// SELL → TP = nearest un-broken SSL (swing low) below entry
f_nearestBSL(float abovePrice) =>
    float nearest = na
    for i = 0 to array.size(pricesBSL) - 1
        if i >= array.size(pricesBSL)
            break
        float p = array.get(pricesBSL, i)
        bool broken = array.get(brokenBSL, i)
        if not broken and p > abovePrice
            if na(nearest) or p < nearest
                nearest := p
    nearest

f_nearestSSL(float belowPrice) =>
    float nearest = na
    for i = 0 to array.size(pricesSSL) - 1
        if i >= array.size(pricesSSL)
            break
        float p = array.get(pricesSSL, i)
        bool broken = array.get(brokenSSL, i)
        if not broken and p < belowPrice
            if na(nearest) or p > nearest
                nearest := p
    nearest

// ─── GENERATE ENTRY SIGNALS ──────────────────────────────────────────────────
// ICT Entry Model (structural SL/TP):
//
// BUY:  SSL Sweep → smart money grabbed liquidity below swing low
//       Entry = close of sweep candle
//       SL    = low of sweep candle (wick extreme — if price breaks this, setup is invalid)
//       TP1   = nearest un-broken BSL (swing high) above entry — next liquidity target
//       TP2   = EQ (equilibrium, partial close)
//
// SELL: BSL Sweep → smart money grabbed liquidity above swing high
//       Entry = close of sweep candle
//       SL    = high of sweep candle (wick extreme — if price breaks this, setup is invalid)
//       TP1   = nearest un-broken SSL (swing low) below entry — next liquidity target
//       TP2   = EQ (equilibrium, partial close)

bool cooldownOk = bar_index - lastSignalBar >= cooldownBars
bool tradeSlotOk = oneAtATime ? not hasActiveTrade : true

if showEntry and barstate.isconfirmed and cooldownOk and tradeSlotOk

    // ── BUY SIGNAL: SSL Sweep in Discount ──
    if sslSweepNow and inDiscount
        bool oteOk = requireOTE ? inOTEBuy : true
        if oteOk and not na(sslSweepPrice)
            float entryPrice = close
            // SL = sweep candle wick low (structural — where smart money finished grabbing)
            float slPrice = low
            float risk = entryPrice - slPrice
            // TP1 = nearest un-broken BSL above entry (next liquidity target)
            float nearBSL = f_nearestBSL(entryPrice)
            float tp1Price = not na(nearBSL) ? nearBSL : entryPrice + risk * rrRatio
            float tp2Price = eq
            float tp3Price = showTP3 ? rangeHigh : na

            if risk > 0 and entryPrice > slPrice
                f_drawTrade(1, entryPrice, slPrice, tp1Price, tp2Price, tp3Price)
                totalBuys += 1
                lastSignalBar := bar_index
                hasActiveTrade := true
                activeSL := slPrice
                activeTP := tp1Price
                activeDir := 1

    // ── SELL SIGNAL: BSL Sweep in Premium ──
    if bslSweepNow and inPremium
        bool oteOk = requireOTE ? inOTESell : true
        if oteOk and not na(bslSweepPrice)
            float entryPrice = close
            // SL = sweep candle wick high (structural)
            float slPrice = high
            float risk = slPrice - entryPrice
            // TP1 = nearest un-broken SSL below entry (next liquidity target)
            float nearSSL = f_nearestSSL(entryPrice)
            float tp1Price = not na(nearSSL) ? nearSSL : entryPrice - risk * rrRatio
            float tp2Price = eq
            float tp3Price = showTP3 ? rangeLow : na

            if risk > 0 and slPrice > entryPrice
                f_drawTrade(-1, entryPrice, slPrice, tp1Price, tp2Price, tp3Price)
                totalSells += 1
                lastSignalBar := bar_index
                hasActiveTrade := true
                activeSL := slPrice
                activeTP := tp1Price
                activeDir := -1

// (SL/TP hit check is above, before signal generation)

// ─── ZONE VISUALIZATION ──────────────────────────────────────────────────────
// Background coloring for zones
bgcolor(showPD and inPremium ? colPrem : na, title="Premium Zone BG")
bgcolor(showPD and inDiscount ? colDisc : na, title="Discount Zone BG")
bgcolor(showOTE and inOTEBuy ? colOTE : na, title="OTE Buy Zone BG")
bgcolor(showOTE and inOTESell ? colOTE : na, title="OTE Sell Zone BG")

// EQ line
plot(showPD ? eq : na, "Equilibrium (50%)", color=colEQ, linewidth=2, style=plot.style_line)

// ─── PREMIUM & DISCOUNT ZONE BOXES ───────────────────────────────────────────
var box premBox  = na
var box discBox  = na
var box oteBoxBuy  = na
var box oteBoxSell = na

if showPD
    box.delete(premBox)
    box.delete(discBox)
    premBox := box.new(bar_index - pdLookback, rangeHigh, bar_index, eq, 
         border_color=color.new(#F23645, 70), bgcolor=color.new(#F23645, 94), 
         border_width=1, border_style=line.style_dotted)
    discBox := box.new(bar_index - pdLookback, eq, bar_index, rangeLow, 
         border_color=color.new(#089981, 70), bgcolor=color.new(#089981, 94), 
         border_width=1, border_style=line.style_dotted)

if showOTE
    box.delete(oteBoxBuy)
    box.delete(oteBoxSell)
    oteBoxBuy := box.new(bar_index - pdLookback, oteBuyHigh, bar_index, oteBuyLow, 
         border_color=color.new(#FF9800, 60), bgcolor=color.new(#FF9800, 92), 
         border_width=1, border_style=line.style_dashed)
    oteBoxSell := box.new(bar_index - pdLookback, oteSellHigh, bar_index, oteSellLow, 
         border_color=color.new(#FF9800, 60), bgcolor=color.new(#FF9800, 92), 
         border_width=1, border_style=line.style_dashed)

// ─── ZONE LABELS ─────────────────────────────────────────────────────────────
var label lblPrem = na
var label lblDisc = na
var label lblEQ   = na
var label lblOTEBuy  = na
var label lblOTESell = na

if showPD
    label.delete(lblPrem)
    label.delete(lblDisc)
    label.delete(lblEQ)
    lblPrem := label.new(bar_index + 5, (rangeHigh + eq) / 2, "PREMIUM", 
         color=color.new(color.white, 100), textcolor=color.new(#F23645, 30), 
         style=label.style_label_left, size=size.small)
    lblDisc := label.new(bar_index + 5, (rangeLow + eq) / 2, "DISCOUNT", 
         color=color.new(color.white, 100), textcolor=color.new(#089981, 30), 
         style=label.style_label_left, size=size.small)
    lblEQ := label.new(bar_index + 5, eq, "EQ", 
         color=color.new(color.white, 100), textcolor=colEQ, 
         style=label.style_label_left, size=size.tiny)

if showOTE
    label.delete(lblOTEBuy)
    label.delete(lblOTESell)
    lblOTEBuy := label.new(bar_index + 5, (oteBuyHigh + oteBuyLow) / 2, "OTE Buy", 
         color=color.new(color.white, 100), textcolor=color.new(#FF9800, 20), 
         style=label.style_label_left, size=size.tiny)
    lblOTESell := label.new(bar_index + 5, (oteSellHigh + oteSellLow) / 2, "OTE Sell", 
         color=color.new(color.white, 100), textcolor=color.new(#FF9800, 20), 
         style=label.style_label_left, size=size.tiny)

// ─── DASHBOARD TABLE ─────────────────────────────────────────────────────────
if showDash
    var table dash = na
    tablePos = switch dashPos
        "Top Right"    => position.top_right
        "Top Left"     => position.top_left
        "Bottom Right"  => position.bottom_right
        "Bottom Left"   => position.bottom_left
        => position.top_right

    if barstate.islast
        int totalTrades = totalTPHits + totalSLHits
        float winRate = totalTrades > 0 ? totalTPHits / totalTrades * 100 : 0

        dash := table.new(tablePos, 2, 9, bgcolor=color.new(#1e222d, 10), border_color=color.new(#363a45, 0), border_width=1, frame_color=color.new(#363a45, 0), frame_width=2)

        // Header
        table.cell(dash, 0, 0, "ICT SSL P&D", text_color=color.white, text_size=size.small, bgcolor=color.new(#2962FF, 20))
        table.cell(dash, 1, 0, "Status", text_color=color.white, text_size=size.small, bgcolor=color.new(#2962FF, 20))

        // Zone
        string zoneText = inPremium ? "PREMIUM ⬆" : "DISCOUNT ⬇"
        color zoneColor = inPremium ? color.new(#F23645, 20) : color.new(#089981, 20)
        table.cell(dash, 0, 1, "Zone", text_color=color.gray, text_size=size.small)
        table.cell(dash, 1, 1, zoneText, text_color=color.white, text_size=size.small, bgcolor=zoneColor)

        // OTE
        string oteText = inOTEBuy ? "OTE BUY 🎯" : inOTESell ? "OTE SELL 🎯" : "—"
        color oteColor = inOTEBuy ? color.new(#FF9800, 30) : inOTESell ? color.new(#FF9800, 30) : color.new(#363a45, 0)
        table.cell(dash, 0, 2, "OTE", text_color=color.gray, text_size=size.small)
        table.cell(dash, 1, 2, oteText, text_color=color.white, text_size=size.small, bgcolor=oteColor)

        // EQ
        table.cell(dash, 0, 3, "EQ", text_color=color.gray, text_size=size.small)
        table.cell(dash, 1, 3, str.tostring(eq, format.mintick), text_color=color.white, text_size=size.small)

        // Sweeps
        table.cell(dash, 0, 4, "Sweeps", text_color=color.gray, text_size=size.small)
        table.cell(dash, 1, 4, "SSL:" + str.tostring(sslSweepCount) + " BSL:" + str.tostring(bslSweepCount), text_color=color.white, text_size=size.small)

        // Trade header
        table.cell(dash, 0, 5, "──────", text_color=color.new(#363a45, 0), text_size=size.small, bgcolor=color.new(#2962FF, 20))
        table.cell(dash, 1, 5, "Trades", text_color=color.white, text_size=size.small, bgcolor=color.new(#2962FF, 20))

        // Signals
        table.cell(dash, 0, 6, "Signals", text_color=color.gray, text_size=size.small)
        table.cell(dash, 1, 6, "🟢" + str.tostring(totalBuys) + " 🔴" + str.tostring(totalSells), text_color=color.white, text_size=size.small)

        // Results
        table.cell(dash, 0, 7, "Results", text_color=color.gray, text_size=size.small)
        table.cell(dash, 1, 7, "✔" + str.tostring(totalTPHits) + " ✖" + str.tostring(totalSLHits), text_color=color.white, text_size=size.small, bgcolor=winRate >= 50 ? color.new(#089981, 30) : totalTrades > 0 ? color.new(#F23645, 30) : color.new(#363a45, 0))

        // Win Rate
        table.cell(dash, 0, 8, "Win %", text_color=color.gray, text_size=size.small)
        table.cell(dash, 1, 8, totalTrades > 0 ? str.tostring(winRate, "#.#") + "%" : "—", text_color=color.white, text_size=size.small)

// ─── ALERTS ──────────────────────────────────────────────────────────────────
alertcondition(ta.crossover(close, eq), "Price crossed above EQ (entering Premium)", "Price entered PREMIUM zone — EQ crossover")
alertcondition(ta.crossunder(close, eq), "Price crossed below EQ (entering Discount)", "Price entered DISCOUNT zone — EQ crossunder")
alertcondition(sslSweepNow and inDiscount, "BUY Signal (SSL Sweep in Discount)", "🟢 BUY: SSL Sweep detected in Discount zone")
alertcondition(bslSweepNow and inPremium, "SELL Signal (BSL Sweep in Premium)", "🔴 SELL: BSL Sweep detected in Premium zone")
